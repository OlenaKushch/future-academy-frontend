{
  "name": "future-academy-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3001",
    "build": "tsc -b && vite build",
    "build:gh-pages": "tsc -b && vite build --mode gh-pages",
